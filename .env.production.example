# VentureERP — production environment template.
#
# Copy this file to .env only on the production host. Replace every CHANGE_ME
# value there; never commit the resulting .env or database credentials.

SERVER_ADDR=5070
ENV=production
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_SEC=15

# The production API and PostgreSQL run on the same host. Keeping PostgreSQL on
# loopback avoids exposing port 5432 to clients or the internet.
DATABASE_URL=postgres://venturerp_app:CHANGE_ME@127.0.0.1:5432/venturerp?sslmode=disable

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Origens do app desktop. O front (axios) roda dentro do WebView Chromium do
# Tauri, então É sujeito a CORS: liste as origens reais do Tauri v2. Windows usa
# http://tauri.localhost; macOS/Linux usam tauri://localhost. Deny-by-default.
CORS_ALLOWED_ORIGINS=tauri://localhost,http://tauri.localhost,https://tauri.localhost
RATE_LIMIT_RPS=50
RATE_LIMIT_BURST=100
AUTH_RATE_LIMIT_RPM=20
AUTH_RATE_LIMIT_BURST=10
MAX_BODY_BYTES=10485760

METRICS_ENABLED=true
METRICS_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_STRING
OTEL_SERVICE_NAME=venturerp-api
OTEL_SERVICE_NAMESPACE=venturerp
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Fila local consumida pelo agente root de atualização da VPS.
SYSTEM_UPDATE_DIR=/var/lib/venturerp-update
BACKEND_RELEASE_URL=https://api.github.com/repos/FelipePn10/venturerp/releases/latest

NESTING_SERVICE_URL=
