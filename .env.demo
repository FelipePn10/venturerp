# Ambiente de APRESENTAÇÃO (demo) — montado como /app/.env no container api-demo.
# NUNCA aponta para produção. DATABASE_URL e JWT_SECRET vêm do ambiente do container.
SERVER_ADDR=5072
ENV=production
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,tauri://localhost,http://tauri.localhost
METRICS_ENABLED=false
RATE_LIMIT_RPS=300
RATE_LIMIT_BURST=600
AUTH_RATE_LIMIT_RPM=300
AUTH_RATE_LIMIT_BURST=150
