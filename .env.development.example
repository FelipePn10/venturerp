# VentureERP — isolated development environment.
# Copy to .env.development and replace every CHANGE_ME value.

SERVER_ADDR=5071
ENV=development
LOG_LEVEL=debug
SHUTDOWN_TIMEOUT_SEC=15

POSTGRES_ADMIN_USER=venturerp_development_admin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
POSTGRES_APP_USER=venturerp_development_app
POSTGRES_APP_PASSWORD=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_PASSWORD
POSTGRES_READONLY_USER=venturerp_development_readonly
POSTGRES_READONLY_PASSWORD=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_PASSWORD
POSTGRES_DB=venturerp_development
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://venturerp_development_app:CHANGE_ME_TO_ANOTHER_LONG_RANDOM_PASSWORD@127.0.0.1:5433/venturerp_development?sslmode=disable

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
CORS_ALLOWED_ORIGINS=tauri://localhost,http://tauri.localhost,https://tauri.localhost
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
AUTH_RATE_LIMIT_RPM=60
AUTH_RATE_LIMIT_BURST=20
MAX_BODY_BYTES=10485760
METRICS_ENABLED=true
METRICS_TOKEN=
TRUSTED_PROXY_CIDRS=

OTEL_SERVICE_NAME=venturerp-api-development
OTEL_SERVICE_NAMESPACE=venturerp
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
