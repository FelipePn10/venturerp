# Installed as /etc/venturerp/update.env with mode 0600.
IMAGE_REPOSITORY=ghcr.io/felipepn10/panossoerp
COMPOSE_FILE=/opt/venturerp/updater/compose.yml
API_ENV_FILE=/opt/venturerp/panossoerp/.env
UPDATE_DIR=/var/lib/venturerp-update
BACKUP_DIR=/var/backups/venturerp/releases
DATABASE_CONTAINER=venturerp-postgres
DATABASE_USER=venturerp_app
DATABASE_NAME=venturerp
DATABASE_URL=postgres://venturerp_app:CHANGE_ME@127.0.0.1:5432/venturerp?sslmode=disable
HEALTH_URL=http://127.0.0.1:5070/health/ready
LEGACY_SERVICE=venturerp.service
HEALTH_ATTEMPTS=30
HEALTH_INTERVAL_SECONDS=2
