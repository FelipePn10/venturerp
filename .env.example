# VentureERP — example environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored; this template is
# committed so everyone knows which variables exist. Defaults (in config.go)
# apply when a variable is omitted.

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_ADDR=5070
ENV=development                 # development | production
LOG_LEVEL=info                  # debug | info | warn | error
SHUTDOWN_TIMEOUT_SEC=15         # graceful drain budget on SIGTERM/SIGINT

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://venturerp_app:CHANGE_ME@localhost:5432/venturerp?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── HTTP hardening ───────────────────────────────────────────────────────────
# Comma-separated allowed origins for the desktop client (Tauri WebView é
# Chromium → sujeito a CORS). Leave EMPTY in development to reflect any origin;
# in production list the Tauri v2 origins explicitly, e.g.
# CORS_ALLOWED_ORIGINS=tauri://localhost,http://tauri.localhost,https://tauri.localhost
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_RPS=50               # sustained requests/sec per IP (<=0 disables)
RATE_LIMIT_BURST=100            # burst capacity per IP
AUTH_RATE_LIMIT_RPM=20          # login/register attempts per minute per IP
AUTH_RATE_LIMIT_BURST=10
MAX_BODY_BYTES=10485760         # request body cap in bytes (10 MiB); 0 disables

# ── Observability ────────────────────────────────────────────────────────────
METRICS_ENABLED=true            # expose Prometheus metrics at GET /metrics
METRICS_TOKEN=                  # required to mount /metrics; use `Authorization: Bearer <token>`
TRUSTED_PROXY_CIDRS=            # comma-separated proxy CIDRs allowed to supply X-Forwarded-For
OTEL_SERVICE_NAME=venturerp-api
OTEL_SERVICE_NAMESPACE=venturerp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # OTLP HTTP exporter (traces → Tempo)

# ── Observability stack (Grafana / Prometheus / Loki / Tempo) ──────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── SMTP (optional — MRP / fiscal e-mail alerts; blank disables) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Plano de Corte — motor de nesting true-shape externo (opcional).
# Quando definido, o corte TRUE_SHAPE_2D delega o nesting irregular a este serviço
# HTTP (ex.: um wrapper DeepNest/ProNest). Vazio = usa o provedor nativo bounding-box.
NESTING_SERVICE_URL=
